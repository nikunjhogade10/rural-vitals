# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ruralcarelink?schema=public"

# JWT
JWT_SECRET="change-this-to-a-strong-random-string"
JWT_REFRESH_SECRET="change-this-to-another-strong-random-string"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"
